rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role, createdAt
    //
    // Collection: projects
    // Fields: name, location, budget, deadline, status, progress, assignedTeam, createdBy, createdAt
    //
    // Sub-collections under projects: labour, attendance, materials, expenses, dpr
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin') || (isAuthenticated() && request.auth.token.email == "sohelsayyed052002@gmail.com");
    }

    function isManager() {
      return isAdmin() || hasRole('manager');
    }

    function isSupervisor() {
      return isManager() || hasRole('supervisor');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'manager', 'supervisor'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'budget', 'status', 'createdBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.budget is number && data.budget >= 0 &&
             data.status in ['planned', 'in-progress', 'completed', 'on-hold'] &&
             data.createdBy == request.auth.uid;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'startDate', 'endDate', 'status', 'projectId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.startDate is string &&
             data.endDate is string &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.projectId is string;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'category', 'date', 'projectId', 'recordedBy']) &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.amount is number && data.amount >= 0 &&
             data.category in ['material', 'labour', 'equipment', 'other'] &&
             data.date is string &&
             data.projectId is string &&
             data.recordedBy is string &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000));
    }

    function isValidLabour(data) {
      return data.keys().hasAll(['name', 'trade', 'dailyWage', 'phoneNumber', 'status', 'projectId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.trade is string &&
             data.dailyWage is number && data.dailyWage >= 0 &&
             data.phoneNumber is string &&
             data.status in ['active', 'inactive'] &&
             data.projectId is string &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Allow system to create (in this case, client-side logic acting as system)
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isSupervisor() && isValidProject(request.resource.data);
      allow update: if isSupervisor() && isValidProject(request.resource.data);
      allow delete: if isAdmin();

      match /tasks/{taskId} {
        allow read: if isAuthenticated();
        allow create: if isSupervisor() && isValidTask(request.resource.data);
        allow update: if isSupervisor() && isValidTask(request.resource.data);
        allow delete: if isAdmin();
      }

      match /labour/{labourId} {
        allow read: if isAuthenticated();
        allow create: if isSupervisor() && isValidLabour(request.resource.data);
        allow update: if isSupervisor() && isValidLabour(request.resource.data);
        allow delete: if isAdmin();
      }

      match /attendance/{attendanceId} {
        allow read: if isAuthenticated();
        allow write: if isSupervisor();
      }

      match /materials/{materialId} {
        allow read: if isAuthenticated();
        allow write: if isSupervisor();
      }

      match /expenses/{expenseId} {
        allow read: if isAuthenticated();
        allow create: if isSupervisor() && isValidExpense(request.resource.data);
        allow update: if isSupervisor() && isValidExpense(request.resource.data);
        allow delete: if isAdmin();
      }

      match /dpr/{dprId} {
        allow read: if isAuthenticated();
        allow write: if isSupervisor();
      }
    }

    // Collection Group Rules
    match /{path=**}/expenses/{expenseId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/labour/{labourId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/materials/{materialId} {
      allow read: if isAuthenticated();
    }
  }
}
